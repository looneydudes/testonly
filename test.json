{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "tag": "cloudflare",
        "address": "1.1.1.1",
        "detour": "proxy-b"
      },
      {
        "tag": "google-dns",
        "address": "8.8.8.8",
        "detour": "proxy-b"
      }
    ]
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
