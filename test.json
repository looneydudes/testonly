{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "tag": "cloudflare-dns",
        "address": "https://1.1.1.1/dns-query",
        "detour": "rootgroup"
      },
      {
        "tag": "local-dns",
        "address": "1.1.1.1",
        "detour": "direct"
      }
    ],
    "final": "cloudflare-dns",
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "address": "172.19.0.1/30",
      "auto_route": true,
      "strict_route": true,
      "stack": "system",
      "sniff": true
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "rootgroup",
      "outbounds": [
        "root-proxy",
        "direct"
      ]
    },
    {
      "type": "selector",
      "tag": "interceptgroup",
      "outbounds": [
        "intercept-proxy",
        "direct"
      ]
    },
    {
      "type": "http",
      "tag": "root-proxy",
      "server": "31.59.20.176",
      "server_port": 6754
    },
    {
      "type": "http",
      "tag": "intercept-proxy",
      "server": "23.95.150.145",
      "server_port": 6114
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "domain": [
          "ifconfig.me",
          "api.ipify.org"
        ],
        "outbound": "interceptgroup"
      },
      {
        "domain_keyword": [
          "video"
        ],
        "outbound": "interceptgroup"
      }
    ],
    "final": "rootgroup",
    "auto_detect_interface": true
  }
}
